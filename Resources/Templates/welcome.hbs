<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{{t "Welcome.Subject"}}</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 2rem;
      background-color: #111113;
      font-family: Arial, Helvetica, sans-serif;
      color: #edeef0;
    "
  >
    <div class="wrapper" style="max-width: 500px; width: 100%; margin: 0 auto">
      <img
        src="https://cdn.wyvern.gg/logo.svg"
        alt="Wyvern Logo"
        style="display: block; margin: 0 auto 1.5rem; max-width: 140px"
      />

      <div
        class="container"
        style="
          background-color: #18191b;
          border: 1px solid #43484e;
          border-radius: 10px;
          padding: 1.5rem;
          box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
          text-align: left;
        "
      >
        <h1
          style="
            margin-top: 0;
            font-size: 22px;
            font-weight: 700;
            color: #edeef0;
          "
        >
          {{t "Emails.Welcome.Title"}}
        </h1>

        <p style="font-size: 15px; line-height: 1.6; margin: 0.8rem 0">
          {{t "Emails.Welcome.Body"}}
        </p>

        <p style="font-size: 15px; line-height: 1.6; margin: 0.8rem 0">
          {{t "Emails.Welcome.ActionPrompt"}}
        </p>

        <a
          href="{{link}}"
          style="
            display: block;
            background-color: #e54666;
            color: #ffffff;
            text-decoration: none;
            padding: 12px 0;
            width: 100%;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 600;
            text-align: center;
            margin: 1rem 0;
          "
        >
          {{t "Emails.Welcome.VerifyButton"}}
        </a>

        <p style="font-size: 12px; color: #b0b4ba; margin: 1rem 0">
          {{t "Emails.Welcome.LinkExpiry"}}
        </p>

        <p style="font-size: 15px; line-height: 1.6; margin: 0.8rem 0">
          {{{t "Emails.Welcome.Support"}}}
        </p>

        <p style="margin: 0; font-size: 15px; line-height: 1.6">
          {{{t "Emails.Welcome.SignOff"}}}
        </p>
      </div> 

      <p
        style="
          font-size: 12px;
          text-align: left;
          color: #b0b4ba;
          margin-top: 0.5rem;
        "
      >
        {{t "CopyrightFooter"}}
      </p>
    </div>
  </body>
</html>
